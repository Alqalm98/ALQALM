<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>القلم — لوحة الإدارة</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --p:#1B4F72;--pl:#2471A3;--pp:#D6EAF8;
  --a:#C9A84C;--al:#FAD7A0;
  --g:#1E8449;--gl:#D5F5E3;
  --r:#C0392B;--rl:#FADBD8;
  --bg:#EEF3F8;--w:#fff;--tx:#1A2533;--tm:#5D6D7E;--b:#D5E0EC;
  --sw:252px
}
body{font-family:Tahoma,Arial,sans-serif;background:var(--bg);color:var(--tx);display:flex;min-height:100vh;font-size:14px}
#sb{width:var(--sw);background:#0F2D48;position:fixed;right:0;top:0;bottom:0;display:flex;flex-direction:column;z-index:200;transition:transform .25s}
#sb.off{transform:translateX(110%)}
#ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:150}
#ov.on{display:block}
.sl{padding:20px 18px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;gap:10px}
.li{width:40px;height:40px;background:linear-gradient(135deg,var(--a),#E8B84B);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.3rem}
.lt h2{color:#fff;font-size:1.2rem;font-weight:700}
.lt p{color:rgba(255,255,255,.4);font-size:.68rem}
.sm{padding:14px 10px;flex:1;overflow-y:auto}
.ml{font-size:.6rem;letter-spacing:.2em;color:rgba(255,255,255,.3);padding:10px 10px 4px}
.mi{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;cursor:pointer;color:rgba(255,255,255,.6);transition:all .15s;margin-bottom:1px}
.mi:hover{background:rgba(255,255,255,.07);color:#fff}
.mi.on{background:var(--a);color:#0F2D48;font-weight:700}
.sf{padding:12px 18px;border-top:1px solid rgba(255,255,255,.07);font-size:.68rem;color:rgba(255,255,255,.2);text-align:center}
#mn{margin-right:var(--sw);flex:1;display:flex;flex-direction:column;transition:margin .25s}
#mn.wide{margin-right:0}
.tb{background:var(--w);padding:12px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--b);position:sticky;top:0;z-index:50}
.tbL{display:flex;align-items:center;gap:12px}
#hbtn{width:34px;height:34px;border-radius:8px;border:1.5px solid var(--b);background:var(--bg);cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px}
#hbtn span{display:block;height:2px;background:var(--p);border-radius:2px}
#hbtn span:nth-child(1){width:16px}#hbtn span:nth-child(2){width:16px}#hbtn span:nth-child(3){width:10px;align-self:flex-end}
#ptitle{font-weight:700;color:var(--p);font-size:1rem}
#psub{font-size:.75rem;color:var(--tm)}
#tact{display:flex;gap:8px}
.ct{padding:22px 24px;flex:1}
.pg{display:none}.pg.on{display:block}
.sg{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:22px}
.sc{background:var(--w);border-radius:12px;padding:16px;border:1px solid var(--b);display:flex;align-items:center;gap:12px}
.si{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0}
.sn{font-size:1.7rem;font-weight:800;line-height:1}
.sl2{font-size:.72rem;color:var(--tm);margin-top:2px}
.pn{background:var(--w);border-radius:12px;border:1px solid var(--b);overflow:hidden;margin-bottom:18px}
.ph{padding:14px 20px;border-bottom:1px solid var(--b);display:flex;align-items:center;justify-content:space-between;font-weight:700}
.pb{padding:20px}
table{width:100%;border-collapse:collapse}
th{background:var(--bg);padding:10px 14px;text-align:right;font-size:.75rem;color:var(--tm);font-weight:600;border-bottom:1px solid var(--b)}
td{padding:10px 14px;border-bottom:1px solid #f0f4f8;font-size:.85rem;vertical-align:middle}
tr:last-child td{border:none}
tr:hover td{background:#f8fafc}
.btn{padding:8px 16px;border-radius:7px;font-size:.82rem;font-weight:600;cursor:pointer;border:none;display:inline-flex;align-items:center;gap:5px;transition:opacity .15s,transform .1s}
.btn:active{transform:scale(.97)}
.bp{background:var(--p);color:#fff}.bp:hover{opacity:.88}
.ba{background:var(--a);color:#0F2D48}.ba:hover{opacity:.88}
.bo{background:transparent;border:1.5px solid var(--b);color:var(--tx)}.bo:hover{border-color:var(--p);color:var(--p)}
.bd{background:var(--rl);color:var(--r);border:1px solid #f1948a}.bd:hover{background:var(--r);color:#fff}
.bg2{background:var(--gl);color:var(--g);border:1px solid #82e0aa}.bg2:hover{background:var(--g);color:#fff}
.bpu{background:#f0e6ff;color:#6c3483;border:1px solid #c39bd3}.bpu:hover{background:#6c3483;color:#fff}
.sm2{padding:5px 10px;font-size:.75rem}
.bx{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:.7rem;font-weight:600}
.bb{background:var(--pp);color:var(--p)}
.bgo{background:#fef9e7;color:#9a6f0a}
.bpu2{background:#f0e6ff;color:#6c3483}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.fi{display:flex;flex-direction:column;gap:5px}.fi.fw{grid-column:1/-1}
label{font-size:.78rem;font-weight:600}
input,select,textarea{padding:9px 12px;border:1.5px solid var(--b);border-radius:7px;font-size:.85rem;font-family:inherit;color:var(--tx);outline:none;transition:border-color .15s}
input:focus,select:focus,textarea:focus{border-color:var(--p)}
select{cursor:pointer}
.mo{position:fixed;inset:0;background:rgba(0,0,0,.52);z-index:500;display:none;align-items:center;justify-content:center}
.mo.on{display:flex}
.md{background:var(--w);border-radius:14px;width:540px;max-width:96vw;max-height:92vh;overflow-y:auto}
.md-lg{width:660px}
.mh{padding:18px 22px;border-bottom:1px solid var(--b);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--w);z-index:1}
.mh h3{font-weight:700;font-size:.95rem}
.xb{width:28px;height:28px;border-radius:7px;border:none;background:var(--bg);cursor:pointer;font-size:1rem}
.xb:hover{background:var(--rl);color:var(--r)}
.mb{padding:20px 22px}
.mf{padding:12px 22px 18px;border-top:1px solid var(--b);display:flex;gap:8px;justify-content:flex-end}
.sr{display:flex;gap:10px;margin-bottom:16px}
.sw2{position:relative;flex:1}
.sw2 input{width:100%;padding-right:36px}
.si2{position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--tm);font-size:.85rem;pointer-events:none}
.em{text-align:center;padding:50px 20px;color:var(--tm)}
.em div{font-size:2.8rem;margin-bottom:12px;opacity:.5}
.em h3{font-size:.95rem;font-weight:600;margin-bottom:4px}
.em p{font-size:.8rem}
.cg{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px}
.cc{background:var(--w);border:1.5px solid var(--b);border-radius:12px;padding:18px 14px;text-align:center;cursor:pointer;transition:all .15s}
.cc:hover{border-color:var(--a);transform:translateY(-2px)}
.cn{font-size:2rem;font-weight:800;color:var(--p);line-height:1;margin-bottom:4px}

/* BOOK GRID */
.bkg{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px}
.bkc{background:var(--w);border:1.5px solid var(--b);border-radius:12px;padding:16px;transition:all .15s;position:relative}
.bkc:hover{border-color:var(--p);transform:translateY(-2px);box-shadow:0 6px 18px rgba(27,79,114,.1)}
.bkc-file{margin-top:10px;background:var(--bg);border-radius:8px;padding:8px 10px;display:flex;align-items:center;gap:8px;font-size:.75rem;cursor:pointer;border:1.5px dashed var(--b);transition:all .15s}
.bkc-file:hover{border-color:var(--p);background:var(--pp)}
.bkc-file.has-file{border-style:solid;border-color:var(--g);background:var(--gl)}
.file-ico{font-size:1.2rem;flex-shrink:0}
.file-name{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--tm)}
.file-name.uploaded{color:var(--g);font-weight:700}

/* BOOK FILE UPLOAD */
.book-upload-zone{border:2px dashed var(--b);border-radius:10px;padding:18px;text-align:center;cursor:pointer;transition:all .2s;background:var(--bg);position:relative}
.book-upload-zone:hover{border-color:var(--p);background:var(--pp)}
.book-upload-zone.has-file{border-color:var(--g);border-style:solid;background:var(--gl)}
.book-upload-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.buz-content{pointer-events:none}

/* CARD GRID */
.cdg{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:16px}
.scd{background:linear-gradient(135deg,#1B4F72,#2471A3);border-radius:14px;color:#fff;cursor:pointer;overflow:hidden;transition:transform .15s,box-shadow .15s}
.scd:hover{transform:translateY(-3px);box-shadow:0 10px 28px rgba(27,79,114,.3)}
.scd-in{padding:16px}
.scd-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.scd-sch{font-size:.68rem;opacity:.7;font-weight:600}
.scd-body{display:flex;align-items:center;gap:12px}
.scd-av{width:48px;height:48px;background:rgba(255,255,255,.15);border-radius:50%;border:2px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:700;flex-shrink:0;overflow:hidden}
.scd-av img{width:100%;height:100%;object-fit:cover}
.scd-nm{font-size:.95rem;font-weight:800;margin-bottom:4px}
.scd-cl{display:inline-block;background:rgba(201,168,76,.25);border:1px solid rgba(201,168,76,.5);color:#FFE082;padding:1px 8px;border-radius:20px;font-size:.67rem;font-weight:700}
.scd-ft{display:flex;justify-content:space-between;margin-top:12px;padding-top:10px;border-top:1px solid rgba(255,255,255,.1)}
.scd-id{font-size:.62rem;opacity:.45;font-family:monospace}
.scd-yr{font-size:.67rem;font-weight:700;color:#FAD7A0}

/* PHOTO UPLOAD */
.photo-upload-area{border:2px dashed var(--b);border-radius:12px;padding:18px;text-align:center;cursor:pointer;transition:all .2s;background:var(--bg);position:relative;overflow:hidden}
.photo-upload-area:hover{border-color:var(--p);background:var(--pp)}
.photo-upload-area.has-photo{border-style:solid;border-color:var(--g);padding:0}
.photo-upload-area input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.photo-preview{width:100%;height:150px;object-fit:cover;border-radius:10px;display:block}
.photo-placeholder{pointer-events:none}
.photo-placeholder div{font-size:2rem;margin-bottom:6px}
.photo-placeholder p{font-size:.78rem;color:var(--tm)}
.remove-photo{position:absolute;top:8px;left:8px;background:var(--r);color:#fff;border:none;border-radius:6px;padding:3px 8px;font-size:.72rem;cursor:pointer;z-index:2}
.tav{width:34px;height:34px;border-radius:50%;background:var(--pp);border:2px solid var(--b);display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;color:var(--p);overflow:hidden;flex-shrink:0}
.tav img{width:100%;height:100%;object-fit:cover}
.td-stu{display:flex;align-items:center;gap:10px}
.db{display:flex;align-items:center;gap:10px;margin-bottom:7px}
.db-lb{width:56px;font-size:.75rem;color:var(--tm);font-weight:600;flex-shrink:0}
.db-br{flex:1;background:var(--bg);border-radius:5px;height:18px;overflow:hidden}
.db-fill{height:100%;background:linear-gradient(90deg,var(--p),var(--pl));border-radius:5px;transition:width .4s}
.db-ct{width:22px;text-align:center;font-size:.75rem;font-weight:700;color:var(--p)}

/* ===== PROFESSIONAL STUDENT CARD ===== */
.pro-card-wrap{display:flex;flex-direction:column;gap:16px}
.pro-card{width:100%;background:linear-gradient(135deg,#0d2137 0%,#1B4F72 50%,#1a5276 100%);border-radius:16px;overflow:hidden;color:#fff;position:relative;box-shadow:0 8px 32px rgba(0,0,0,.3)}
.pro-card::before{content:'';position:absolute;top:-40px;left:-40px;width:180px;height:180px;background:radial-gradient(circle,rgba(201,168,76,.18) 0%,transparent 70%);border-radius:50%}
.pro-card::after{content:'';position:absolute;bottom:-30px;right:-30px;width:140px;height:140px;background:radial-gradient(circle,rgba(255,255,255,.06) 0%,transparent 70%);border-radius:50%}
.pc-stripe{height:6px;background:linear-gradient(90deg,var(--a),#f0d060,var(--a));position:relative;z-index:1}
.pc-body{padding:16px 20px;position:relative;z-index:1;display:flex;gap:16px;align-items:center}
.pc-photo{width:80px;height:90px;border-radius:10px;border:2.5px solid rgba(201,168,76,.7);overflow:hidden;flex-shrink:0;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800}
.pc-photo img{width:100%;height:100%;object-fit:cover}
.pc-info{flex:1;min-width:0}
.pc-school{font-size:.62rem;opacity:.55;font-weight:700;letter-spacing:.08em;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.pc-school::before{content:'✏️';font-size:.9rem}
.pc-name{font-size:1.05rem;font-weight:800;margin-bottom:6px;line-height:1.3}
.pc-badges{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px}
.pc-badge{padding:2px 10px;border-radius:20px;font-size:.65rem;font-weight:700}
.pc-badge-gold{background:rgba(201,168,76,.25);border:1px solid rgba(201,168,76,.6);color:#FFE082}
.pc-badge-white{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);color:rgba(255,255,255,.85)}
.pc-meta{font-size:.68rem;opacity:.55;display:flex;flex-direction:column;gap:2px}
.pc-right{display:flex;flex-direction:column;align-items:center;gap:8px;flex-shrink:0}
.pc-qr-box{background:#fff;border-radius:8px;padding:5px;width:72px;height:72px;display:flex;align-items:center;justify-content:center}
.pc-qr-box canvas,.pc-qr-box img{width:62px!important;height:62px!important}
.pc-qr-label{font-size:.55rem;opacity:.45;text-align:center}
.pc-footer{background:rgba(0,0,0,.25);padding:10px 20px;display:flex;justify-content:space-between;align-items:center;position:relative;z-index:1}
.pc-id{font-family:monospace;font-size:.65rem;opacity:.5;letter-spacing:.05em}
.pc-yr{font-size:.68rem;color:#FAD7A0;font-weight:700}
.pc-validity{font-size:.6rem;opacity:.4}

/* PRINT CARD */
@media print{
  body>*:not(.prt){display:none!important}
  .prt{display:block!important;position:fixed;inset:0;background:#fff}
  .prt-inner{display:flex;flex-wrap:wrap;gap:6mm;padding:8mm;align-content:flex-start}
  .prc-pro{width:85.6mm;height:54mm;background:linear-gradient(135deg,#0d2137,#1B4F72,#1a5276)!important;border-radius:4mm;color:#fff!important;print-color-adjust:exact;-webkit-print-color-adjust:exact;overflow:hidden;page-break-inside:avoid;position:relative;font-family:Tahoma,Arial,sans-serif}
  .prc-pro::before{content:'';position:absolute;top:-8mm;left:-8mm;width:30mm;height:30mm;background:radial-gradient(circle,rgba(201,168,76,.18) 0%,transparent 70%)}
  .prc-stripe{height:2.5mm;background:linear-gradient(90deg,#C9A84C,#f0d060,#C9A84C)!important;print-color-adjust:exact;-webkit-print-color-adjust:exact}
  .prc-body{padding:3mm 4mm;display:flex;gap:3mm;align-items:center;position:relative;z-index:1}
  .prc-photo{width:17mm;height:20mm;border-radius:2mm;border:0.5mm solid rgba(201,168,76,.7);overflow:hidden;flex-shrink:0;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:14pt;font-weight:800}
  .prc-photo img{width:100%;height:100%;object-fit:cover}
  .prc-info{flex:1}
  .prc-school{font-size:5pt;opacity:.6;font-weight:700;margin-bottom:2mm}
  .prc-name{font-size:10pt;font-weight:800;margin-bottom:1.5mm}
  .prc-badges{display:flex;gap:1mm;flex-wrap:wrap;margin-bottom:1.5mm}
  .prc-badge{padding:0.5mm 2mm;border-radius:3mm;font-size:5.5pt;font-weight:700}
  .prc-badge-gold{background:rgba(201,168,76,.3)!important;color:#FFE082!important;border:0.3mm solid rgba(201,168,76,.6);print-color-adjust:exact;-webkit-print-color-adjust:exact}
  .prc-badge-w{background:rgba(255,255,255,.15)!important;color:rgba(255,255,255,.9)!important;border:0.3mm solid rgba(255,255,255,.3);print-color-adjust:exact;-webkit-print-color-adjust:exact}
  .prc-right{display:flex;flex-direction:column;align-items:center;gap:1mm;flex-shrink:0}
  .prc-qr{background:#fff!important;border-radius:1.5mm;padding:1mm;width:15mm;height:15mm;display:flex;align-items:center;justify-content:center;print-color-adjust:exact;-webkit-print-color-adjust:exact}
  .prc-qr canvas,.prc-qr img{width:13mm!important;height:13mm!important}
  .prc-qr-lbl{font-size:4pt;opacity:.4;text-align:center}
  .prc-footer{background:rgba(0,0,0,.25)!important;padding:1.5mm 4mm;display:flex;justify-content:space-between;align-items:center;print-color-adjust:exact;-webkit-print-color-adjust:exact}
  .prc-id{font-family:monospace;font-size:5pt;opacity:.5}
  .prc-yr{font-size:5.5pt;color:#FAD7A0!important;font-weight:700;print-color-adjust:exact;-webkit-print-color-adjust:exact}
}

#toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(60px);background:#1A2533;color:#fff;padding:10px 20px;border-radius:8px;font-size:.82rem;font-weight:600;z-index:9999;transition:transform .25s;white-space:nowrap}
#toast.on{transform:translateX(-50%) translateY(0)}
#toast.ok{background:var(--g)}
#toast.er{background:var(--r)}
.prt{display:none}
</style>
</head>
<body>

<div id="ov" onclick="tog()"></div>

<!-- SIDEBAR -->
<aside id="sb">
  <div class="sl">
    <div class="li">✏️</div>
    <div class="lt"><h2>القلم</h2><p>لوحة الإدارة</p></div>
  </div>
  <div class="sm">
    <div class="ml">الرئيسية</div>
    <div class="mi on" onclick="go('dash',this)"><span>🏠</span> لوحة التحكم</div>
    <div class="ml">الإدارة</div>
    <div class="mi" onclick="go('stu',this)"><span>👨‍🎓</span> الطلاب</div>
    <div class="mi" onclick="go('cls',this)"><span>🏫</span> الصفوف</div>
    <div class="mi" onclick="go('bk',this)"><span>📚</span> الكتب والملفات</div>
    <div class="mi" onclick="go('cd',this)"><span>🪪</span> البطاقات</div>
  </div>
  <div class="sf">© 2025 القلم — الإدارة</div>
</aside>

<!-- MAIN -->
<main id="mn">
  <div class="tb">
    <div class="tbL">
      <button id="hbtn" onclick="tog()"><span></span><span></span><span></span></button>
      <div><div id="ptitle">لوحة التحكم</div><div id="psub">مرحباً بك في نظام القلم</div></div>
    </div>
    <div id="tact"></div>
  </div>

  <div class="ct">

    <!-- DASHBOARD -->
    <div class="pg on" id="p-dash">
      <div class="sg">
        <div class="sc"><div class="si" style="background:var(--pp)">👨‍🎓</div><div><div class="sn" id="ds-s">0</div><div class="sl2">الطلاب</div></div></div>
        <div class="sc"><div class="si" style="background:#fef9e7">🏫</div><div><div class="sn">9</div><div class="sl2">الصفوف</div></div></div>
        <div class="sc"><div class="si" style="background:var(--gl)">📚</div><div><div class="sn" id="ds-b">0</div><div class="sl2">الكتب</div></div></div>
        <div class="sc"><div class="si" style="background:#f0e6ff">📄</div><div><div class="sn" id="ds-f">0</div><div class="sl2">الملفات</div></div></div>
        <div class="sc"><div class="si" style="background:var(--rl)">🪪</div><div><div class="sn" id="ds-c">0</div><div class="sl2">البطاقات</div></div></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px">
        <div class="pn">
          <div class="ph">🕐 آخر الطلاب <button class="btn bo sm2" onclick="go('stu',document.querySelectorAll('.mi')[3])">عرض الكل</button></div>
          <div id="ds-list"><div class="em"><div>👨‍🎓</div><p>لا يوجد طلاب بعد</p></div></div>
        </div>
        <div class="pn">
          <div class="ph">📊 توزيع الطلاب على الصفوف</div>
          <div id="ds-dist" style="padding:14px 20px"></div>
        </div>
      </div>
